# Assisted by: cursor, claude
# Personal Quay mirror overrides for local Helm deploy.
# Fork chart defaults (values.yaml) use quay.io/thom_at_redhat/caisat (private, robot credentials).
# Use this file when mirroring to your own Quay user instead of the fork defaults:
#   cp chart/values-quay-local.yaml.example chart/values-quay-local.yaml
#
# Deploy:
#   helm upgrade --install caisat ./chart -f chart/values-quay-local.yaml

model:
  image:
    repository: quay.io/<your-quay-user>/caisat
    tag: "model"

detection:
  image:
    repository: quay.io/<your-quay-user>/caisat
    tag: "yoloobb"

backend:
  image:
    repository: quay.io/<your-quay-user>/caisat
    tag: "backend"

detectionBackend:
  image:
    repository: quay.io/<your-quay-user>/caisat
    tag: "detection-backend"

frontend:
  image:
    repository: quay.io/<your-quay-user>/caisat
    tag: "frontend"

# Pull secret for private Quay images (secret created in namespace, not in git):
imagePullSecrets:
  - name: quay-pull-secret
